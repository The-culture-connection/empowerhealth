# Align with current Xcode / SDKs (FlutterFire + gRPC are tested heavily at 15+).
platform :ios, '15.0'

# Pin native Firebase Apple SDK (overrides firebase_core default, e.g. 11.x).
# Xcode 26.4 + Swift 6.3 + Firebase 11.x can hit Swift concurrency allocator aborts
# ("Freed pointer was not the last allocation") under Release; 12.12.0 includes related fixes
# (see firebase-ios-sdk Swift/async + Firestore issues around #15974 / #16033).
$FirebaseSDKVersion = '12.12.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} is missing. From the Flutter project root (parent of ios/), run: flutter pub get   then: cd ios && pod install"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  # Static linkage avoids a class of Release-only native crashes / memory corruption seen
  # when many dynamic Firebase + gRPC frameworks interact under whole-module Swift -O.
  # If clean builds hang in Xcode, temporarily revert to `use_frameworks!` (dynamic).
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end

